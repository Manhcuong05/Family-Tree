{
  "info": {
    "name": "GiaPha API Collection",
    "description": "Collection for testing GiaPha Spring Boot Backend (Auth + Members)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password123\",\n    \"role\": \"SUPER_ADMIN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login (Auto-set Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "    console.log(\"Token saved to variables!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Members (Gia Phả)",
      "item": [
        {
          "name": "Create Root Member (Thủy Tổ)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"member\": {\n        \"hoTen\": \"Trần Văn Tổ\",\n        \"gioiTinh\": \"MALE\",\n        \"ngaySinh\": \"1800-01-01\",\n        \"isAlive\": false,\n        \"ngayMat\": \"1880-01-01\",\n        \"soDoi\": 1\n    }\n}"
            },
            "url": {
              "raw": "{{base_url}}/members",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "members"
              ]
            }
          }
        },
        {
          "name": "Create Child Member",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"parentId\": \"<REPLACE_WITH_ROOT_ID>\",\n    \"relationshipType\": \"RUOT\",\n    \"member\": {\n        \"hoTen\": \"Trần Văn F1\",\n        \"gioiTinh\": \"MALE\",\n        \"ngaySinh\": \"1825-01-01\",\n        \"isAlive\": false,\n        \"soDoi\": 2\n    }\n}"
            },
            "url": {
              "raw": "{{base_url}}/members",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "members"
              ]
            }
          }
        },
        {
          "name": "Get Family Tree Flat (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/members/tree/<REPLACE_WITH_ROOT_ID>",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "members",
                "tree",
                "<REPLACE_WITH_ROOT_ID>"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
